#!/usr/bin/env bash
# Runs the fast check before every push. Mirror of CI's fast gate —
# catches drift/typecheck/test regressions in ~3s so you don't burn a
# CI minute to find out.
#
# Opt in:  git config core.hooksPath .githooks
# Opt out: git config --unset core.hooksPath
# Bypass:  git push --no-verify
#
# Keep this fast. If it grows past ~10s, move the slow checks to the
# `check:full` script and only run the fast half here.

set -euo pipefail

echo "[pre-push] running design-system drift check + typecheck + tests…"
npm run check

echo "[pre-push] clean."
