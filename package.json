{
  "name": "grove-www",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:mobile": "playwright test",
    "test:e2e": "playwright test --config=playwright.e2e.config.ts",
    "test:visual": "playwright test --config=playwright.visual.config.ts",
    "test:visual:update": "playwright test --config=playwright.visual.config.ts --update-snapshots",
    "typecheck": "tsc --noEmit",
    "lint:drift": "bash scripts/drift-check.sh",
    "check": "npm run lint:drift && npm run typecheck && npm run test",
    "check:full": "npm run check && npm run test:mobile && npm run test:visual"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "d3": "^7.9.0",
    "lucide-react": "^1.8.0",
    "mermaid": "^11.14.0",
    "next": "^16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rehype-katex": "^7.0.1",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.0.2",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/d3": "^7.4.3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
